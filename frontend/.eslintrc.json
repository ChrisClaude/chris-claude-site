{
  "extends": ["next/core-web-vitals", "prettier"],
  "plugins": ["prettier"],
  "ignorePatterns": ["src/**/__generated__/**"],
  "rules": {
    "prettier/prettier": "error",
    "comma-dangle": ["error", "always-multiline"],
    "semi": ["error", "always"],
    "object-curly-spacing": ["error", "always"]
  }
}
