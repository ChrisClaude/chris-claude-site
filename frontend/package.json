{
  "name": "chris-claude-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "npm": ">=10.8.2",
    "node": ">=20.14.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "pre-commit": "lint-staged",
    "generate-api-client": "openapi-generator-cli generate -i ${OPENAPI_URL:-http://localhost:6003/openapi/v1.json} -g typescript-fetch -o src/app/_lib/codegen"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.427.0",
    "@heroicons/react": "^2.2.0",
    "@heroui/react": "^2.8.4",
    "@microsoft/applicationinsights-react-js": "^19.3.8",
    "@microsoft/applicationinsights-web": "^3.3.11",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/node": "20.3.1",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "10.4.14",
    "dompurify": "^3.0.6",
    "framer-motion": "^12.23.13",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^3.0.1",
    "marked": "^9.1.0",
    "next": "16.0.10",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^4.11.0",
    "react-loader-spinner": "^5.4.5",
    "react-redux": "^9.2.0",
    "server-only": "0.0.1",
    "tailwindcss": "3.3.2",
    "typescript": "5.1.3"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.31.0",
    "@types/dompurify": "^3.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^18.3.23",
    "@types/react-loader-spinner": "^4.0.0",
    "eslint": "8.57.0",
    "eslint-config-next": "^15.4.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@openapitools/openapi-generator-cli"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
